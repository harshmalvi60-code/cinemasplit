26:"$Sreact.suspense"
27:I[9286,["762","static/chunks/44530001-ad5bf9d336177563.js","724","static/chunks/724-55a00210804537cb.js","678","static/chunks/678-7f53e876ccf7273f.js","185","static/chunks/app/layout-6bb344ccf67ff55b.js"],"default"]
7:{"title":"Perfect Days","director":"Wim Wenders","year":2023,"rating":9.3,"mood":"gold","story":"A Tokyo public-toilet cleaner lives a routine of cassette tapes, paperbacks, and small kindnesses. The film follows him quietly through several days.","why":"A film that argues a small, devoted life is a complete life. Cassette tapes, tree light through windshields, the same sandwich for lunch.","after":"You’ll respect your own routine.","direction":"Wenders at his most restrained. Pure observation as direction.","cinematography":"Franz Lustig. Light through trees — the protagonist’s favourite phenomenon — becomes the film’s visual signature.","musicSound":"Cassette playlist of Lou Reed, Patti Smith, Otis Redding. Better than any score.","impact":"You leave wanting to live more like the man in the film. Few films do that any more.","overall":"One of the best of the decade."}
8:{"title":"Paterson","director":"Jim Jarmusch","year":2016,"rating":8.7,"mood":"water","story":"A bus driver in Paterson, New Jersey, named Paterson, writes poems between routes. The film follows seven days of his quiet, devoted life.","why":"About finding poetry in the bus route and the cereal box. Cinema as a way of slowing your attention down enough to be alive.","after":"You’ll notice one thing you usually miss.","direction":"Jarmusch at his most patient. Small kindnesses as plot points.","cinematography":"Frederick Elmes shoots a working New Jersey city with no condescension.","musicSound":"Sqürl ambient score by Jarmusch himself. Drifts like the bus does.","impact":"The notebook scene near the end. Devastating in a register usually reserved for thrillers.","overall":"A perfect small film."}
9:{"title":"Columbus","director":"Kogonada","year":2017,"rating":8.7,"mood":"ice","story":"A young woman caring for her mother in Columbus, Indiana, befriends a Korean-American man waiting on his dying father — and they talk, slowly, about everything.","why":"Two people walk through buildings and talk about how to be useful to your own life. Quietly transformative.","after":"You’ll take a walk without a destination.","direction":"Kogonada’s debut. Years of video essays distilled into one slow, formally precise film.","cinematography":"Elisha Christian’s architecture-as-character framing. Every frame is wallpaper.","musicSound":"Hammock’s ambient score under long quiet conversations.","impact":"A film that calms your pulse while sharpening your attention.","overall":"One of the most beautiful American debuts of recent years."}
a:{"title":"Before Sunrise","director":"Richard Linklater","year":1995,"rating":9,"mood":"gold","story":"A young American man and a young French woman meet on a train, decide to spend one night walking around Vienna together, and talk until dawn.","why":"A long, low-stakes conversation between two strangers. Real intimacy is a pace, not a plot point.","after":"You’ll stay in one conversation for the rest of the evening.","direction":"Linklater treats real-time talk like an action sequence — long, alert, unbroken.","cinematography":"Lee Daniel shoots Vienna at night as warmly as any city has been shot.","musicSound":"No score. The city is the soundtrack.","impact":"The listening-booth scene is one of cinema’s most quietly romantic minutes.","overall":"A foundational film. Spawned imitators that mostly missed why it works."}
b:{"title":"Into the Wild","director":"Sean Penn","year":2007,"rating":8.4,"mood":"gold","story":"A young man abandons his possessions, savings, and family after graduating, hitchhiking toward Alaska in search of an honest life. Based on a true story.","why":"When the speed of your life has gone wrong and you need a film that respects how much landscape it takes to reset.","after":"You’ll be still for a longer minute than usual.","direction":"Penn lets the road dictate the structure.","cinematography":"Eric Gautier’s wide American landscape photography is genuinely transporting.","musicSound":"Eddie Vedder’s solo soundtrack is essentially the protagonist’s inner life.","impact":"The final notebook pages re-frame the entire journey.","overall":"Better than its reputation. A useful film for big-decision seasons."}
c:{"title":"Minari","director":"Lee Isaac Chung","year":2020,"rating":8.8,"mood":"dawn","story":"A Korean-American family moves to rural Arkansas in the 1980s to start a farm. The film is a slow, attentive portrait of building a life in unfamiliar soil.","why":"About growing something slowly with your own hands. The film treats patience and family as the same agricultural project.","after":"You’ll plant something — even metaphorically.","direction":"Chung’s autobiographical film about his own childhood. Affection without sentimentality.","cinematography":"Lachlan Milne shoots rural Arkansas like a country an immigrant family is choosing into.","musicSound":"Emile Mosseri’s score is one of the best of the decade. Genuinely transcendent.","impact":"The grandmother’s arc is the film’s emotional engine, against all expectations.","overall":"A modern classic in the making."}
d:{"title":"The Straight Story","director":"David Lynch","year":1999,"rating":8.9,"mood":"gold","story":"A seventy-three-year-old man drives a lawnmower across two American states to visit his estranged, ailing brother. Based on a true story.","why":"An old man drives a lawnmower across two states to make peace with his brother. The film moves at the pace of the mower, on purpose.","after":"You’ll be willing to take longer to arrive.","direction":"Lynch’s most uncharacteristic film and quietly one of his best.","cinematography":"Freddie Francis’ final film as cinematographer. Open American plains.","musicSound":"Angelo Badalamenti’s gentle Americana score — unlike his Lynch noir work.","impact":"The final shot at his brother’s porch is one of cinema’s most earned silences.","overall":"A perfect film. Almost no one mentions Lynch when they recommend it."}
e:{"title":"My Neighbor Totoro","director":"Hayao Miyazaki","year":1988,"rating":9.1,"mood":"gold","story":"Two young sisters move to the countryside with their father to be closer to their hospitalised mother, and find the woods near their house are full of friendly spirits.","why":"The part of you that needs to be told the world is mostly safe and the wind in the trees is the point.","after":"You’ll listen for the wind instead of the news.","direction":"Miyazaki at his most uncynical. A film about safety, drawn at master level.","cinematography":"Hand-drawn cel animation. The cat bus is now folklore.","musicSound":"Joe Hisaishi’s score is essentially Studio Ghibli’s heartbeat.","impact":"A film that calms anxious children and anxious adults equally.","overall":"A foundational text. Re-watchable for life."}
f:{"title":"Spring, Summer, Fall, Winter… and Spring","director":"Kim Ki-duk","year":2003,"rating":8.7,"mood":"water","story":"A young monk’s life unfolds across five seasons in a tiny Buddhist temple that floats on a remote Korean lake.","why":"A life lived in seasons inside a floating temple. The film is a meditation, not a movie.","after":"You’ll let a season pass without measuring it.","direction":"Kim Ki-duk’s most contemplative film. Far from his harsher work.","cinematography":"The floating temple set, photographed across actual seasons. The location is the cast.","musicSound":"Park Ji-woong’s score plus chanting. Sparse and patient.","impact":"Five chapters, five seasons, an entire life. Few films cover this much with this little.","overall":"A formal achievement. Almost no one has made another film like it."}
10:{"title":"After Yang","director":"Kogonada","year":2021,"rating":8.3,"mood":"ice","story":"When the family’s android “brother” breaks down, a father tries to repair him — and discovers, in the process, a record of small everyday moments.","why":"A family’s sleek AI breaks down and the film follows the gentle work of grieving and remembering it. Stillness as the storytelling.","after":"You’ll re-watch a memory you usually rush past.","direction":"Kogonada’s second feature. Even more patient than Columbus.","cinematography":"Benjamin Loeb shoots a near-future home with the warmth of a Vermeer.","musicSound":"Aska Matsumiya’s score plus a recurring Mitski song — a brilliant unconventional pairing.","impact":"The opening title-credit dance sequence is now a film-class reference for cinematic kineticism.","overall":"Quieter than it had to be. Better for the choice."}
11:{"title":"Tokyo Story","director":"Yasujirō Ozu","year":1953,"rating":9.5,"mood":"gold","story":"An elderly couple travel from rural Japan to Tokyo to visit their adult children. They find the children too busy to make time for them.","why":"About the peace that comes from accepting how things are rather than how they should be. Ozu’s final statement on family.","after":"You’ll call your parents.","direction":"Ozu’s low-angle tatami-level camera. Stillness as formal philosophy.","cinematography":"Yūharu Atsuta. Postwar Japan.","musicSound":"Takanobu Saitō. Gentle and sad.","impact":"Repeatedly voted one of the five greatest films ever made.","overall":"The most universally loved film of Japan’s classical era."}
12:{"title":"Pather Panchali","director":"Satyajit Ray","year":1955,"rating":9.3,"mood":"water","story":"A poor rural family in Bengal — a father who dreams of writing, a mother managing the household, and two children growing up.","why":"About the peace of life lived entirely in the present, without the resources to plan for more.","after":"You’ll be still.","direction":"Ray’s first film. Made over several years with whatever he had.","cinematography":"Subrata Mitra. Bengal in natural light.","musicSound":"Ravi Shankar. Sitar as landscape.","impact":"Launched Indian art cinema onto the world stage.","overall":"One of cinema’s foundational works. Essential."}
13:{"title":"Yi Yi","director":"Edward Yang","year":2000,"rating":9.5,"mood":"dusk","story":"A Taipei family across three generations navigates a year of life. Nobody is the protagonist; life itself is.","why":"About the peace that comes from accepting that ordinary days are the material of a life.","after":"You’ll look at the back of someone’s head and wonder what they see.","direction":"Yang’s final film. 173 minutes without a wasted frame.","cinematography":"Wei-han Yang. Apartment windows. Reflection.","musicSound":"Peng Kai-li. Classical piano over modern life.","impact":"Cannes Best Director. Among the greatest films of the century.","overall":"A summit. Return to it every few years."}
14:{"title":"A Beautiful Day in the Neighborhood","director":"Marielle Heller","year":2019,"rating":8.5,"mood":"gold","story":"A cynical journalist is assigned to profile Fred Rogers and finds himself disarmed by a man who says exactly what he means.","why":"About the peace that one patient, fully-present person can offer to someone who has never felt it.","after":"You’ll give one person your full attention.","direction":"Heller uses the Mister Rogers set as literal structure.","cinematography":"Jody Lee Lipes. Quiet and careful.","musicSound":"Nate Heller. Piano-warm.","impact":"Tom Hanks as Rogers. The trolley sequences. The silence experiment.","overall":"The best film about kindness as practice."}
15:{"title":"Once","director":"John Carney","year":2006,"rating":8.8,"mood":"rose","story":"A street musician and a Czech immigrant woman make music together over a week in Dublin.","why":"About the peace of total presence in the making of something. The film is those seven days.","after":"You’ll play music for someone.","direction":"Carney shoots consumer camera intimacy in real Dublin.","cinematography":"Tilman Büttner.","musicSound":"Glen Hansard and Markéta Irglová. The songs are the film.","impact":"Falling Slowly. An Oscar song that earned it.","overall":"A film that earns its feeling entirely through music."}
16:{"title":"The Band's Visit","director":"Eran Kolirin","year":2007,"rating":8.8,"mood":"dawn","story":"An Egyptian police orchestra is stranded in a small Israeli desert town. The night they spend changes everyone.","why":"About the peace that arrives when two groups of strangers agree to just sit with each other.","after":"You’ll make one small act of welcome.","direction":"Kolirin keeps the tone dry and the warmth deep.","cinematography":"Shai Goldman. Desert town flatness.","musicSound":"Arabic and Egyptian music played live.","impact":"The tango lesson scene.","overall":"A small masterpiece of cross-cultural warmth."}
17:{"title":"Babette's Feast","director":"Gabriel Axel","year":1987,"rating":8.9,"mood":"gold","story":"A French refugee housekeeper spends her lottery winnings on one extraordinary meal for the austere Danish village that sheltered her.","why":"About the peace that arrives when beauty is finally allowed to enter a world that has been refusing it.","after":"You’ll cook something with real care.","direction":"Axel treats the feast as liturgy.","cinematography":"Henning Kristiansen. Danish winter and feast warmth.","musicSound":"Per Nørgård. The meal is the music.","impact":"Best Foreign Film Oscar. The meal scene is one of cinema’s great.","overall":"Perfect and gentle. A film about grace."}
18:{"title":"Tampopo","director":"Jūzō Itami","year":1985,"rating":8.9,"mood":"gold","story":"A truck driver helps a widow improve her ramen shop. Surrounding this story are vignettes about food and desire.","why":"About the peace of mastery. The devoted perfection of one bowl of ramen.","after":"You’ll eat the next meal with more attention.","direction":"Itami mixes genres without confusion.","cinematography":"Masaki Tamura. Japanese restaurant kitchens.","musicSound":"Kunihiko Murai. Playful and warm.","impact":"Invented a genre: the ramen western.","overall":"One of the great food films. One of the great comedies."}
19:{"title":"Chef's Table Season 1","director":"David Gelb","year":2015,"rating":8.7,"mood":"gold","story":"Six chefs across the world discuss their philosophy of food and their process of becoming who they are.","why":"About the peace of doing one thing with absolute devotion.","after":"You’ll find one thing to do devotedly.","direction":"Gelb treats food as art and chefs as artists.","cinematography":"Beautifully shot food across six countries.","musicSound":"Mark Degli Antoni. Classical elegance.","impact":"Redefined the food documentary.","overall":"Season 1, episodes 1-3 in particular."}
1a:{"title":"The Straight Story","director":"David Lynch","year":1999,"rating":8.9,"mood":"gold","story":"A seventy-three-year-old man drives a lawnmower across Iowa and Wisconsin to visit his ailing brother.","why":"About the peace that comes from moving slowly toward something important.","after":"You’ll be willing to take longer to arrive.","direction":"Lynch’s most uncharacteristic and quietly perfect film.","cinematography":"Freddie Francis. Great Plains in late light.","musicSound":"Angelo Badalamenti. His gentlest score.","impact":"The final shot at the brother’s porch.","overall":"A perfect film. Almost never mentioned alongside Lynch’s major work."}
1b:{"title":"Three Colors: Blue","director":"Krzysztof Kieślowski","year":1993,"rating":9.2,"mood":"water","story":"A woman who loses her family in a car crash tries to live as if she has no connections to anyone or anything.","why":"About the peace that cannot be reached by avoiding grief — and the slow impossible discovery that connection survives our attempts to sever it.","after":"You’ll stop trying to be unattached.","direction":"Kieślowski’s most internal film.","cinematography":"Sławomir Idziak. Blue-saturated Paris.","musicSound":"Zbigniew Preisner. The score is woven into the plot.","impact":"Juliette Binoche’s finest performance.","overall":"A pillar of 90s European cinema."}
1c:{"title":"Ramen Shop","director":"Eric Khoo","year":2018,"rating":8,"mood":"gold","story":"A young Japanese chef travels to Singapore to find his mother’s side of the family and reconcile with her memory through food.","why":"About the peace that comes from completing the journey through the person who left.","after":"You’ll cook one of your parent’s recipes.","direction":"Khoo handles the tender material with respect.","cinematography":"Brian Gothong Tan. Singapore and Japan.","musicSound":"Food sounds as score.","impact":"A food film that is really a grief film.","overall":"Modest and warm. Under the radar."}
1d:{"title":"Jiro Dreams of Sushi","director":"David Gelb","year":2011,"rating":8.9,"mood":"gold","story":"An eighty-five-year-old sushi master in a Tokyo subway restaurant has three Michelin stars and is still trying to improve.","why":"About the peace of total devotion. A man who found his thing and never stopped learning it.","after":"You’ll give one hour of total attention to your craft.","direction":"Gelb treats the obsession with quiet awe.","cinematography":"Beautiful close-up food photography.","musicSound":"Philip Glass in a surprising fit.","impact":"The film that made the modern chef documentary.","overall":"Meditative and moving. One of the great food docs."}
1e:{"title":"Waltz with Bashir","director":"Ari Folman","year":2008,"rating":8.8,"mood":"night","story":"An animated documentary: a filmmaker investigates his own missing memories from the 1982 Lebanon War.","why":"About the peace that cannot come until the blocked memory is faced. The film is the archaeology.","after":"You’ll face the memory you’ve been around.","direction":"Folman in animated documentary form. Formally unprecedented.","cinematography":"Animated style by David Polonsky.","musicSound":"Max Richter and others. The ending live-action shift.","impact":"Golden Globe Best Foreign Film. A work of real moral courage.","overall":"One of the great documentaries. One of the great anti-war films."}
20:["world","inner-peace","d"]
21:["emotion","slowing-down","d"]
