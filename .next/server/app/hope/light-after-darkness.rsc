27:I[9286,["762","static/chunks/44530001-ad5bf9d336177563.js","724","static/chunks/724-55a00210804537cb.js","678","static/chunks/678-7f53e876ccf7273f.js","185","static/chunks/app/layout-6bb344ccf67ff55b.js"],"default"]
7:{"title":"The Shawshank Redemption","director":"Frank Darabont","year":1994,"rating":9.6,"mood":"gold","story":"A banker sentenced to life in Shawshank State Prison for a crime he insists he didn’t commit forms a long friendship with a fellow inmate. Hope, as work, across decades.","why":"Hope as the stubborn, daily refusal to forget that the outside still exists.","after":"You’ll keep the small daily practice that keeps you going.","direction":"Darabont adapts Stephen King’s novella with patience and faith in his lead actors.","cinematography":"Roger Deakins. The rooftop tar scene and the rain-in-the-river finale are textbook.","musicSound":"Thomas Newman’s score is one of the most-licensed in film history. The Mozart sequence is one of cinema’s great spiritual minutes.","impact":"Why it remains the #1 film on IMDb after thirty years.","overall":"Possibly the most universally loved film of the last fifty years."}
8:{"title":"Soul","director":"Pete Docter","year":2020,"rating":9,"mood":"gold","story":"A middle-school music teacher who finally lands the gig of his dreams dies on the same day — and finds himself in a celestial waystation, trying to get back.","why":"A film that argues that ordinary life is the point. Hope reframed as already-having, not still-waiting.","after":"You’ll be grateful for one normal thing.","direction":"Pixar’s most adult statement.","cinematography":"Two visual realms. Same craft.","musicSound":"Reznor, Ross, Batiste. A nearly perfect score.","impact":"Aimed at kids, lands hardest on adults.","overall":"Pixar peak. Better every rewatch."}
9:{"title":"Life is Beautiful","director":"Roberto Benigni","year":1997,"rating":9,"mood":"gold","story":"An Italian Jewish father in WWII Tuscany invents an elaborate game to shield his young son from the horror of the concentration camp they are sent to.","why":"A father turns horror into a game so his son can survive it psychologically. Hope as an act of authorship by the adults in the room.","after":"You’ll be a quieter believer in front of someone younger.","direction":"Benigni directs himself. The risky tonal bet pays off because he commits fully.","cinematography":"Tonino Delli Colli’s Tuscan light first half, austere camp grey second half. The contrast is the structure.","musicSound":"Nicola Piovani’s Oscar-winning score. Achingly warm.","impact":"Polarising on Holocaust films generally. Lands for those who let it.","overall":"Won Best Foreign and Best Actor at the Oscars. One of the most-talked-about films of its decade."}
a:{"title":"Good Will Hunting","director":"Gus Van Sant","year":1997,"rating":9.1,"mood":"gold","story":"A self-taught janitor at MIT, secretly a mathematical prodigy, is taken on by a math professor and a therapist who refuse to let him sabotage his future.","why":"About one person deciding, on your behalf, that you are not the worst thing that ever happened to you.","after":"You’ll trust the people who refuse to give up on you.","direction":"Van Sant lets the script (by Affleck and Damon) lead.","cinematography":"Boston in late-90s practical lighting. Never beautified.","musicSound":"Danny Elfman plus Elliott Smith. The Smith placements are perfect.","impact":"The “it’s not your fault” scene retains its power.","overall":"Aged into modern canon."}
b:{"title":"Little Miss Sunshine","director":"Dayton & Faris","year":2006,"rating":8.7,"mood":"gold","story":"A dysfunctional family piles into a yellow VW van to drive their seven-year-old daughter from Albuquerque to a Californian beauty pageant.","why":"A family loses on every conventional metric and ends the film dancing anyway. The most hopeful ending of its decade, in disguise.","after":"You’ll dance on the metric you actually care about.","direction":"Dayton and Faris turn ensemble comedy into emotional craft.","cinematography":"Southwest sunlight without flattening.","musicSound":"Mychael Danna with DeVotchKa’s gypsy-folk textures. Half the film’s warmth.","impact":"The final pageant scene is one of the great act-three turns of the 2000s.","overall":"Indie sleeper that aged into perennial recommendation."}
c:{"title":"Jojo Rabbit","director":"Taika Waititi","year":2019,"rating":8.6,"mood":"fire","story":"A lonely German boy with an imaginary friend version of Hitler discovers his mother is hiding a Jewish girl in their attic.","why":"Hope inside a setting that should make hope impossible. The film argues that even a child’s heart can refuse the era it was born into.","after":"You’ll question the inherited ideas you haven’t questioned.","direction":"Waititi balances absurdist comedy with quietly devastating drama.","cinematography":"Mihai Malaimare Jr.’s storybook-Germany palette.","musicSound":"Michael Giacchino plus needle drops. The Bowie cover sequence is the entire thesis in two minutes.","impact":"The shoes scene. You know the one. Probably the best single shot in modern Holocaust cinema.","overall":"Risky concept, fully executed. Earned its Oscar."}
d:{"title":"About Time","director":"Richard Curtis","year":2013,"rating":8.4,"mood":"dawn","story":"A young man learns the men in his family can travel in time — and slowly discovers the gift isn’t about changing the past but paying attention to the present.","why":"Time travel used to learn the radical lesson that today, lived once, with attention, is enough. Sneakily a masterpiece.","after":"You’ll re-do today, in your head, with more attention.","direction":"Richard Curtis at his most disciplined. The high-concept stays small on purpose.","cinematography":"John Guleserian’s warm Cornwall and London light.","musicSound":"The Nick Cave “Into My Arms” sequence is unforgettable.","impact":"A film whose final-act lesson re-reads as wisdom about a year after watching.","overall":"Disarmingly underrated. Quiet best-of-decade."}
e:{"title":"The Intouchables","director":"Nakache & Toledano","year":2011,"rating":9,"mood":"gold","story":"A young man from the Paris housing estates is hired to be the live-in caregiver to a wealthy quadriplegic aristocrat. An unlikely friendship rebuilds both lives.","why":"About the friendship that lets two men become more themselves. Hope as the right person showing up at the right time.","after":"You’ll be the right person to someone today.","direction":"Nakache and Toledano lean on chemistry. They are right to.","cinematography":"Mathieu Vadepied shoots Paris with affection but without postcard cliches.","musicSound":"Ludovico Einaudi plus classical and soul. Possibly the most-streamed soundtrack on this list.","impact":"A French smash that crossed every cultural border to become a global hit.","overall":"One of the most beloved feel-good films of the 2010s. Earned it."}
f:{"title":"Chef","director":"Jon Favreau","year":2014,"rating":8.2,"mood":"fire","story":"A high-end LA chef whose career is sabotaged by a critic and a restaurant owner buys a food truck with his son and slowly remembers why he started cooking.","why":"A man who lost the love of his work finds it back via a food truck and his son. Hope as the rebuild from your own kitchen.","after":"You’ll do one thing for the love of it, not the result.","direction":"Favreau in pure crowd-pleaser mode and proud of it.","cinematography":"Kramer Morgenthau makes food look like cinematography, not garnish.","musicSound":"Latin-soul soundtrack as rhythm section for the road-trip portion.","impact":"A film that makes you hungry, sentimental, and slightly inspired — in that order.","overall":"Comfort food cinema. Re-watchable on rainy weekends."}
10:{"title":"Wonder","director":"Stephen Chbosky","year":2017,"rating":8.4,"mood":"dawn","story":"A boy born with facial differences attends mainstream school for the first time in fifth grade. The film follows the year from his perspective and the people around him.","why":"About a kid the world wanted to look away from, and a year of people slowly learning to look.","after":"You’ll really see one person today.","direction":"Chbosky shifts perspectives generously. The film respects more than just its protagonist.","cinematography":"Don Burgess shoots an autumnal New York. Schoolyard light done well.","musicSound":"Marcelo Zarvos’ score knows when to step aside.","impact":"A family film that adults cry through. Specifically about being seen.","overall":"Better than its modest profile. A quiet, generous film."}
11:{"title":"The Green Mile","director":"Frank Darabont","year":1999,"rating":8.6,"mood":"gold","story":"A death row guard in 1935 meets an inmate with inexplicable healing powers. Based on Stephen King’s serial novel.","why":"About the hope that arrives in the form of a person who cannot be explained.","after":"You’ll be gentler with the next stranger.","direction":"Darabont’s patient Americana.","cinematography":"David Tattersall. Prison block in Southern heat.","musicSound":"Thomas Newman. His warmest work.","impact":"Michael Clarke Duncan’s John Coffey.","overall":"The Shawshank companion. Equally moving."}
12:{"title":"Forrest Gump","director":"Robert Zemeckis","year":1994,"rating":8.8,"mood":"gold","story":"A man with a low IQ from Alabama lives through fifty years of American history through sheer luck, kindness, and love for one woman.","why":"About hope as the unreasonable persistence of goodness in a world that keeps punishing it.","after":"You’ll do the next thing in front of you without overthinking it.","direction":"Zemeckis handles fifty years without losing the human scale.","cinematography":"Don Burgess. American landscape across five decades.","musicSound":"Alan Silvestri’s feather theme. One of cinema’s great motifs.","impact":"The bench monologue. The run. Six Oscars.","overall":"Culturally inescapable for a reason. Holds up."}
13:{"title":"Schindler's List","director":"Steven Spielberg","year":1993,"rating":9.5,"mood":"ash","story":"A German businessman in occupied Kraków uses his factory to save over a thousand Jewish workers from the Holocaust.","why":"About hope as the stubborn, costly refusal of one person to accept the world as it is.","after":"You’ll do the small good thing.","direction":"Spielberg’s most morally serious film.","cinematography":"Janusz Kamiński. Black-and-white with one red coat.","musicSound":"John Williams’ violin theme. Among the great scores of any decade.","impact":"Seven Oscars. The most important film of the 90s.","overall":"Essential."}
14:{"title":"Slumdog Millionaire","director":"Danny Boyle","year":2008,"rating":8.6,"mood":"gold","story":"A teenager from the Mumbai slums appears on Who Wants to Be a Millionaire and is suspected of cheating. His life story is how he knew the answers.","why":"About hope that refuses the narrative others have written for you.","after":"You’ll claim the thing everyone said wasn’t meant for you.","direction":"Boyle at his most kinetic and generous.","cinematography":"Anthony Dod Mantle. Mumbai at full speed.","musicSound":"A.R. Rahman’s score won the Oscar. Rightfully.","impact":"Best Picture. The Jai Ho sequence.","overall":"A film that makes joy feel possible."}
15:{"title":"Pay It Forward","director":"Mimi Leder","year":2000,"rating":7.6,"mood":"gold","story":"A seventh-grade boy creates a movement: do something good for three strangers, who each do the same for three more.","why":"About hope as a contagion. The film argues goodness can spread beyond the original giver.","after":"You’ll do something for someone who cannot repay you.","direction":"Leder handles the premise without cynicism.","cinematography":"Oliver Stapleton.","musicSound":"Thomas Newman. Warm.","impact":"Haley Joel Osment at eleven. A child performance of real weight.","overall":"Modest. Genuinely useful."}
16:{"title":"Hacksaw Ridge","director":"Mel Gibson","year":2016,"rating":8.5,"mood":"fire","story":"Desmond Doss, a Seventh-day Adventist who refused to carry a weapon, served as a combat medic at Okinawa and saved seventy-five lives.","why":"About hope as the individual refusal to abandon your values when the world makes it most costly.","after":"You’ll hold your ground on one thing.","direction":"Gibson handles the pacifism and the war with equal seriousness.","cinematography":"Simon Duggan. War in brutal scale.","musicSound":"Rupert Gregson-Williams. Medal-of-honour music.","impact":"Andrew Garfield’s career-best performance.","overall":"A surprising war film from a surprising director. Two Oscars."}
17:{"title":"Hidden Figures","director":"Theodore Melfi","year":2016,"rating":8.4,"mood":"gold","story":"Three Black women mathematicians at NASA calculate the trajectories for the early space program in 1960s Virginia.","why":"About hope as the refusal to be erased by the system designed to erase you.","after":"You’ll claim credit for something you earned.","direction":"Melfi directs with belief in his subjects.","cinematography":"Mandy Walker. NASA Americana.","musicSound":"Pharrell Williams-produced score. Warm and propulsive.","impact":"Taraji P. Henson, Octavia Spencer, Janelle Monáe. Three performances, one engine.","overall":"Best Picture nominee. A crowd-pleaser with a genuine point."}
18:{"title":"Coco","director":"Lee Unkrich","year":2017,"rating":9,"mood":"gold","story":"A Mexican boy travels to the Land of the Dead on Día de los Muertos and learns that memory is what keeps love alive.","why":"About hope as the refusal to let anyone be forgotten. The dead live as long as we say their names.","after":"You’ll say a name you haven’t said in a while.","direction":"Pixar at its full emotional range.","cinematography":"Land of the Dead sequences. Some of Pixar’s finest.","musicSound":"Michael Giacchino and the Lopezes. Remember Me.","impact":"The final reveal with abuela. Unmatched in recent Pixar.","overall":"One of Pixar’s few perfect films."}
19:{"title":"Life is Beautiful","director":"Roberto Benigni","year":1997,"rating":9,"mood":"gold","story":"A father turns a concentration camp into a game to protect his young son’s psychological survival.","why":"About hope as an act of authorship. He cannot change the world but he can change how his son experiences it.","after":"You’ll be a quieter believer in front of someone younger.","direction":"Benigni directs himself. The tonal risk earns itself.","cinematography":"Tonino Delli Colli. Tuscany into grey camp.","musicSound":"Nicola Piovani. Achingly warm.","impact":"Best Actor Oscar for Benigni. One of the most emotional Oscar speeches.","overall":"A film people debate and then cry through."}
1a:{"title":"The Intouchables","director":"Nakache & Toledano","year":2011,"rating":9,"mood":"gold","story":"A young man from the housing estates is hired as caregiver to a wealthy quadriplegic. An unlikely friendship rebuilds both their lives.","why":"About hope as the right person showing up when you have stopped expecting anyone to.","after":"You’ll be the right person to someone today.","direction":"The chemistry between Cluzet and Sy is the film.","cinematography":"Mathieu Vadepied. Paris without postcard.","musicSound":"Ludovico Einaudi. His most-streamed work.","impact":"The highest-grossing French film ever made.","overall":"A crowd-pleaser that earns every tear."}
1b:{"title":"Gifted","director":"Marc Webb","year":2017,"rating":8,"mood":"dawn","story":"A man raises his gifted seven-year-old niece and fights a legal battle against his mother for her.","why":"About hope as the protection of someone’s ordinary childhood against those who would exploit their gifts.","after":"You’ll protect one ordinary thing about someone exceptional.","direction":"Webb handles the material honestly.","cinematography":"Stuart Dryburgh. Florida light.","musicSound":"Rob Simonsen. Small and warm.","impact":"McKenna Grace. An extraordinary child performance.","overall":"A small, honest family film."}
1c:{"title":"Wonder","director":"Stephen Chbosky","year":2017,"rating":8.4,"mood":"dawn","story":"A boy born with facial differences attends mainstream school for the first time in fifth grade. The film follows everyone around him.","why":"About hope as the act of being truly seen by someone who could look away.","after":"You’ll really see one person today.","direction":"Chbosky shifts perspectives generously.","cinematography":"Don Burgess. School year.","musicSound":"Marcelo Zarvos.","impact":"Jacob Tremblay and the supporting cast. A generous ensemble.","overall":"A family film with adult intelligence."}
1d:{"title":"Captain Fantastic","director":"Matt Ross","year":2016,"rating":8.3,"mood":"gold","story":"A father who raised his children off-grid must navigate the outside world’s expectations.","why":"About hope as the refusal to abandon your values when the world makes it inconvenient.","after":"You’ll question one thing you do because everyone else does.","direction":"Ross makes the idealism complicated.","cinematography":"Stéphane Fontaine.","musicSound":"Alex Somers.","impact":"Viggo Mortensen warmly. Rare.","overall":"Cannes Competition. One of the decade’s better family films."}
1e:{"title":"Eddie the Eagle","director":"Dexter Fletcher","year":2015,"rating":7.8,"mood":"gold","story":"Michael Edwards, Britain’s first Olympic ski jumper, finishes last in Calgary 1988 and is beloved for it.","why":"About hope as showing up for the thing you will not win.","after":"You’ll show up for the thing anyway.","direction":"Fletcher treats the material with respect.","cinematography":"George Richmond. Alpine whites.","musicSound":"80s needle drops. Hans Zimmer at the first jump.","impact":"Taron Egerton becoming the actor he would be.","overall":"Modest and warm. Earns its ending."}
20:["world","hope","d"]
21:["emotion","light-after-darkness","d"]
0:["-l06LWa9y3QJYd9Q3nt3y",[[["",{"children":[["world","hope","d"],{"children":[["emotion","light-after-darkness","d"],{"children":["__PAGE__?{\"world\":\"hope\",\"emotion\":\"light-after-darkness\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":[["world","hope","d"],{"children":[["emotion","light-after-darkness","d"],{"children":["__PAGE__",{},[["$L1",[["$","div",null,{"aria-hidden":true,"className":"fixed inset-0 pointer-events-none z-0","style":{"background":"\n      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(255,216,122,0.28) 0%, transparent 55%)\n    "}}],["$","div",null,{"className":"relative overflow-hidden","children":[["$","$L2",null,{"worldSlug":"hope"}],["$","$L3",null,{"currentPath":"/hope/light-after-darkness"}],["$","div",null,{"className":"relative z-10 max-w-[1440px] mx-auto px-5 md:px-12","children":[["$","div",null,{"className":"flex items-center gap-3 text-[11px] tracking-[0.2em] uppercase text-ink-muted pt-10 pb-5 font-semibold","children":[["$","$L4",null,{"href":"/","className":"hover:text-ink transition-colors duration-300 no-underline flex items-center gap-2","children":"← All worlds"}],["$","span",null,{"className":"text-ink-faint","children":"/"}],["$","span",null,{"className":"text-ink","children":["World ","11"]}]]}],["$","section",null,{"className":"pb-20 md:pb-28","children":[["$","div",null,{"className":"mb-8 flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.42em] text-accent","children":[["$","span",null,{"className":"inline-block h-px w-8 bg-accent"}],"World ","11"," · ",1," ","state"]}],["$","h1",null,{"className":"text-[64px] sm:text-[100px] md:text-[140px] lg:text-[180px] font-bold leading-[0.92] tracking-[-0.035em] text-ink mb-6","children":"Hope"}],["$","p",null,{"className":"text-[18px] md:text-[24px] lg:text-[28px] leading-[1.4] text-ink-soft max-w-[760px] font-normal tracking-[-0.005em]","children":"Films for the unreasonable conviction that something good is still possible — and the people whose lives become an argument for it."}]]}]]}]]}],["$","main",null,{"className":"max-w-[1440px] mx-auto px-5 md:px-12 relative z-[1]","children":[["$","section",null,{"className":"border-b border-line","children":[["$","div",null,{"className":"flex items-center gap-3 text-[11px] tracking-[0.32em] uppercase text-ink-muted font-semibold pt-10 pb-4","children":[["$","span",null,{"className":"inline-block w-5 h-px bg-ink-faint"}],"Choose an emotion"]}],["$","div",null,{"className":"flex flex-wrap gap-2 md:gap-3 pb-8","children":[["$","$L4","light-after-darkness",{"href":"/hope/light-after-darkness","className":"text-[14px] md:text-[15px] font-semibold tracking-[-0.005em] px-5 py-2.5 rounded-full transition-all duration-300 no-underline bg-accent text-bg shadow-[0_0_24px_rgba(19,237,255,0.35)]","children":"Light After Darkness"}]]}]]}],["$","section",null,{"className":"border-b border-white/8 py-12 md:py-16","children":["$","div",null,{"className":"max-w-[720px]","children":[["$","div",null,{"className":"mb-5 flex items-center gap-3","children":[["$","span",null,{"className":"h-px w-6 bg-accent/60"}],["$","span",null,{"className":"text-[10px] font-semibold uppercase tracking-[0.3em] text-accent/70","children":["On ","Light After Darkness"]}]]}],["$","p",null,{"className":"text-[16px] font-normal leading-[1.8] text-ink-soft md:text-[18px]","children":"You have been in the dark long enough that hope feels like a risk. Better to stay cautious. Better not to believe in things that might not come true. And then something happens — a line in a film, a stranger's act, a moment of ordinary grace — that makes the calculated caution feel less like wisdom and more like fear wearing a coat. These films are not motivational. They are not easy. They are arguments, carefully made, that hope is not naive — it is the most stubborn, evidence-based position available to a person who has been paying attention to how many mornings have arrived anyway."}]]}]}],["$","section",null,{"className":"py-16 md:py-20","children":[["$","div",null,{"className":"flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10 md:mb-14","children":[["$","div",null,{"children":[["$","div",null,{"className":"flex items-center gap-3 mb-4 text-[11px] tracking-[0.32em] uppercase text-ink-muted font-semibold","children":[["$","span",null,{"className":"inline-block w-5 h-px bg-ink-faint"}],"Light After Darkness"]}],["$","h2",null,{"className":"text-[32px] md:text-[44px] lg:text-[56px] font-bold leading-[1.05] tracking-[-0.025em] text-ink max-w-[820px]","children":"Films for the morning that arrives anyway."}]]}],["$","div",null,{"className":"text-[12px] tracking-[0.18em] uppercase text-ink-muted font-semibold md:text-right shrink-0","children":[["$","span",null,{"className":"block text-[44px] md:text-[56px] text-ink font-bold tracking-[-0.03em] normal-case leading-none","children":"24"}],["$","span",null,{"className":"mt-2 block","children":"Curated films"}]]}]]}],["$","div",null,{"className":"py-10 border-b border-white/6 mb-10","children":["$","$L5",null,{"films":[{"title":"The Shawshank Redemption","director":"Frank Darabont","year":1994,"rating":9.6,"mood":"gold","story":"A banker sentenced to life in Shawshank State Prison for a crime he insists he didn’t commit forms a long friendship with a fellow inmate. Hope, as work, across decades.","why":"Hope as the stubborn, daily refusal to forget that the outside still exists.","after":"You’ll keep the small daily practice that keeps you going.","direction":"Darabont adapts Stephen King’s novella with patience and faith in his lead actors.","cinematography":"Roger Deakins. The rooftop tar scene and the rain-in-the-river finale are textbook.","musicSound":"Thomas Newman’s score is one of the most-licensed in film history. The Mozart sequence is one of cinema’s great spiritual minutes.","impact":"Why it remains the #1 film on IMDb after thirty years.","overall":"Possibly the most universally loved film of the last fifty years."},{"title":"Soul","director":"Pete Docter","year":2020,"rating":9,"mood":"gold","story":"A middle-school music teacher who finally lands the gig of his dreams dies on the same day — and finds himself in a celestial waystation, trying to get back.","why":"A film that argues that ordinary life is the point. Hope reframed as already-having, not still-waiting.","after":"You’ll be grateful for one normal thing.","direction":"Pixar’s most adult statement.","cinematography":"Two visual realms. Same craft.","musicSound":"Reznor, Ross, Batiste. A nearly perfect score.","impact":"Aimed at kids, lands hardest on adults.","overall":"Pixar peak. Better every rewatch."},{"title":"Life is Beautiful","director":"Roberto Benigni","year":1997,"rating":9,"mood":"gold","story":"An Italian Jewish father in WWII Tuscany invents an elaborate game to shield his young son from the horror of the concentration camp they are sent to.","why":"A father turns horror into a game so his son can survive it psychologically. Hope as an act of authorship by the adults in the room.","after":"You’ll be a quieter believer in front of someone younger.","direction":"Benigni directs himself. The risky tonal bet pays off because he commits fully.","cinematography":"Tonino Delli Colli’s Tuscan light first half, austere camp grey second half. The contrast is the structure.","musicSound":"Nicola Piovani’s Oscar-winning score. Achingly warm.","impact":"Polarising on Holocaust films generally. Lands for those who let it.","overall":"Won Best Foreign and Best Actor at the Oscars. One of the most-talked-about films of its decade."},{"title":"Good Will Hunting","director":"Gus Van Sant","year":1997,"rating":9.1,"mood":"gold","story":"A self-taught janitor at MIT, secretly a mathematical prodigy, is taken on by a math professor and a therapist who refuse to let him sabotage his future.","why":"About one person deciding, on your behalf, that you are not the worst thing that ever happened to you.","after":"You’ll trust the people who refuse to give up on you.","direction":"Van Sant lets the script (by Affleck and Damon) lead.","cinematography":"Boston in late-90s practical lighting. Never beautified.","musicSound":"Danny Elfman plus Elliott Smith. The Smith placements are perfect.","impact":"The “it’s not your fault” scene retains its power.","overall":"Aged into modern canon."},{"title":"Little Miss Sunshine","director":"Dayton & Faris","year":2006,"rating":8.7,"mood":"gold","story":"A dysfunctional family piles into a yellow VW van to drive their seven-year-old daughter from Albuquerque to a Californian beauty pageant.","why":"A family loses on every conventional metric and ends the film dancing anyway. The most hopeful ending of its decade, in disguise.","after":"You’ll dance on the metric you actually care about.","direction":"Dayton and Faris turn ensemble comedy into emotional craft.","cinematography":"Southwest sunlight without flattening.","musicSound":"Mychael Danna with DeVotchKa’s gypsy-folk textures. Half the film’s warmth.","impact":"The final pageant scene is one of the great act-three turns of the 2000s.","overall":"Indie sleeper that aged into perennial recommendation."},{"title":"Jojo Rabbit","director":"Taika Waititi","year":2019,"rating":8.6,"mood":"fire","story":"A lonely German boy with an imaginary friend version of Hitler discovers his mother is hiding a Jewish girl in their attic.","why":"Hope inside a setting that should make hope impossible. The film argues that even a child’s heart can refuse the era it was born into.","after":"You’ll question the inherited ideas you haven’t questioned.","direction":"Waititi balances absurdist comedy with quietly devastating drama.","cinematography":"Mihai Malaimare Jr.’s storybook-Germany palette.","musicSound":"Michael Giacchino plus needle drops. The Bowie cover sequence is the entire thesis in two minutes.","impact":"The shoes scene. You know the one. Probably the best single shot in modern Holocaust cinema.","overall":"Risky concept, fully executed. Earned its Oscar."},{"title":"About Time","director":"Richard Curtis","year":2013,"rating":8.4,"mood":"dawn","story":"A young man learns the men in his family can travel in time — and slowly discovers the gift isn’t about changing the past but paying attention to the present.","why":"Time travel used to learn the radical lesson that today, lived once, with attention, is enough. Sneakily a masterpiece.","after":"You’ll re-do today, in your head, with more attention.","direction":"Richard Curtis at his most disciplined. The high-concept stays small on purpose.","cinematography":"John Guleserian’s warm Cornwall and London light.","musicSound":"The Nick Cave “Into My Arms” sequence is unforgettable.","impact":"A film whose final-act lesson re-reads as wisdom about a year after watching.","overall":"Disarmingly underrated. Quiet best-of-decade."},{"title":"The Intouchables","director":"Nakache & Toledano","year":2011,"rating":9,"mood":"gold","story":"A young man from the Paris housing estates is hired to be the live-in caregiver to a wealthy quadriplegic aristocrat. An unlikely friendship rebuilds both lives.","why":"About the friendship that lets two men become more themselves. Hope as the right person showing up at the right time.","after":"You’ll be the right person to someone today.","direction":"Nakache and Toledano lean on chemistry. They are right to.","cinematography":"Mathieu Vadepied shoots Paris with affection but without postcard cliches.","musicSound":"Ludovico Einaudi plus classical and soul. Possibly the most-streamed soundtrack on this list.","impact":"A French smash that crossed every cultural border to become a global hit.","overall":"One of the most beloved feel-good films of the 2010s. Earned it."},{"title":"Chef","director":"Jon Favreau","year":2014,"rating":8.2,"mood":"fire","story":"A high-end LA chef whose career is sabotaged by a critic and a restaurant owner buys a food truck with his son and slowly remembers why he started cooking.","why":"A man who lost the love of his work finds it back via a food truck and his son. Hope as the rebuild from your own kitchen.","after":"You’ll do one thing for the love of it, not the result.","direction":"Favreau in pure crowd-pleaser mode and proud of it.","cinematography":"Kramer Morgenthau makes food look like cinematography, not garnish.","musicSound":"Latin-soul soundtrack as rhythm section for the road-trip portion.","impact":"A film that makes you hungry, sentimental, and slightly inspired — in that order.","overall":"Comfort food cinema. Re-watchable on rainy weekends."},{"title":"Wonder","director":"Stephen Chbosky","year":2017,"rating":8.4,"mood":"dawn","story":"A boy born with facial differences attends mainstream school for the first time in fifth grade. The film follows the year from his perspective and the people around him.","why":"About a kid the world wanted to look away from, and a year of people slowly learning to look.","after":"You’ll really see one person today.","direction":"Chbosky shifts perspectives generously. The film respects more than just its protagonist.","cinematography":"Don Burgess shoots an autumnal New York. Schoolyard light done well.","musicSound":"Marcelo Zarvos’ score knows when to step aside.","impact":"A family film that adults cry through. Specifically about being seen.","overall":"Better than its modest profile. A quiet, generous film."},{"title":"The Green Mile","director":"Frank Darabont","year":1999,"rating":8.6,"mood":"gold","story":"A death row guard in 1935 meets an inmate with inexplicable healing powers. Based on Stephen King’s serial novel.","why":"About the hope that arrives in the form of a person who cannot be explained.","after":"You’ll be gentler with the next stranger.","direction":"Darabont’s patient Americana.","cinematography":"David Tattersall. Prison block in Southern heat.","musicSound":"Thomas Newman. His warmest work.","impact":"Michael Clarke Duncan’s John Coffey.","overall":"The Shawshank companion. Equally moving."},{"title":"Forrest Gump","director":"Robert Zemeckis","year":1994,"rating":8.8,"mood":"gold","story":"A man with a low IQ from Alabama lives through fifty years of American history through sheer luck, kindness, and love for one woman.","why":"About hope as the unreasonable persistence of goodness in a world that keeps punishing it.","after":"You’ll do the next thing in front of you without overthinking it.","direction":"Zemeckis handles fifty years without losing the human scale.","cinematography":"Don Burgess. American landscape across five decades.","musicSound":"Alan Silvestri’s feather theme. One of cinema’s great motifs.","impact":"The bench monologue. The run. Six Oscars.","overall":"Culturally inescapable for a reason. Holds up."},{"title":"Schindler's List","director":"Steven Spielberg","year":1993,"rating":9.5,"mood":"ash","story":"A German businessman in occupied Kraków uses his factory to save over a thousand Jewish workers from the Holocaust.","why":"About hope as the stubborn, costly refusal of one person to accept the world as it is.","after":"You’ll do the small good thing.","direction":"Spielberg’s most morally serious film.","cinematography":"Janusz Kamiński. Black-and-white with one red coat.","musicSound":"John Williams’ violin theme. Among the great scores of any decade.","impact":"Seven Oscars. The most important film of the 90s.","overall":"Essential."},{"title":"Slumdog Millionaire","director":"Danny Boyle","year":2008,"rating":8.6,"mood":"gold","story":"A teenager from the Mumbai slums appears on Who Wants to Be a Millionaire and is suspected of cheating. His life story is how he knew the answers.","why":"About hope that refuses the narrative others have written for you.","after":"You’ll claim the thing everyone said wasn’t meant for you.","direction":"Boyle at his most kinetic and generous.","cinematography":"Anthony Dod Mantle. Mumbai at full speed.","musicSound":"A.R. Rahman’s score won the Oscar. Rightfully.","impact":"Best Picture. The Jai Ho sequence.","overall":"A film that makes joy feel possible."},{"title":"Pay It Forward","director":"Mimi Leder","year":2000,"rating":7.6,"mood":"gold","story":"A seventh-grade boy creates a movement: do something good for three strangers, who each do the same for three more.","why":"About hope as a contagion. The film argues goodness can spread beyond the original giver.","after":"You’ll do something for someone who cannot repay you.","direction":"Leder handles the premise without cynicism.","cinematography":"Oliver Stapleton.","musicSound":"Thomas Newman. Warm.","impact":"Haley Joel Osment at eleven. A child performance of real weight.","overall":"Modest. Genuinely useful."},{"title":"Hacksaw Ridge","director":"Mel Gibson","year":2016,"rating":8.5,"mood":"fire","story":"Desmond Doss, a Seventh-day Adventist who refused to carry a weapon, served as a combat medic at Okinawa and saved seventy-five lives.","why":"About hope as the individual refusal to abandon your values when the world makes it most costly.","after":"You’ll hold your ground on one thing.","direction":"Gibson handles the pacifism and the war with equal seriousness.","cinematography":"Simon Duggan. War in brutal scale.","musicSound":"Rupert Gregson-Williams. Medal-of-honour music.","impact":"Andrew Garfield’s career-best performance.","overall":"A surprising war film from a surprising director. Two Oscars."},{"title":"Hidden Figures","director":"Theodore Melfi","year":2016,"rating":8.4,"mood":"gold","story":"Three Black women mathematicians at NASA calculate the trajectories for the early space program in 1960s Virginia.","why":"About hope as the refusal to be erased by the system designed to erase you.","after":"You’ll claim credit for something you earned.","direction":"Melfi directs with belief in his subjects.","cinematography":"Mandy Walker. NASA Americana.","musicSound":"Pharrell Williams-produced score. Warm and propulsive.","impact":"Taraji P. Henson, Octavia Spencer, Janelle Monáe. Three performances, one engine.","overall":"Best Picture nominee. A crowd-pleaser with a genuine point."},{"title":"Coco","director":"Lee Unkrich","year":2017,"rating":9,"mood":"gold","story":"A Mexican boy travels to the Land of the Dead on Día de los Muertos and learns that memory is what keeps love alive.","why":"About hope as the refusal to let anyone be forgotten. The dead live as long as we say their names.","after":"You’ll say a name you haven’t said in a while.","direction":"Pixar at its full emotional range.","cinematography":"Land of the Dead sequences. Some of Pixar’s finest.","musicSound":"Michael Giacchino and the Lopezes. Remember Me.","impact":"The final reveal with abuela. Unmatched in recent Pixar.","overall":"One of Pixar’s few perfect films."},{"title":"Life is Beautiful","director":"Roberto Benigni","year":1997,"rating":9,"mood":"gold","story":"A father turns a concentration camp into a game to protect his young son’s psychological survival.","why":"About hope as an act of authorship. He cannot change the world but he can change how his son experiences it.","after":"You’ll be a quieter believer in front of someone younger.","direction":"Benigni directs himself. The tonal risk earns itself.","cinematography":"Tonino Delli Colli. Tuscany into grey camp.","musicSound":"Nicola Piovani. Achingly warm.","impact":"Best Actor Oscar for Benigni. One of the most emotional Oscar speeches.","overall":"A film people debate and then cry through."},{"title":"The Intouchables","director":"Nakache & Toledano","year":2011,"rating":9,"mood":"gold","story":"A young man from the housing estates is hired as caregiver to a wealthy quadriplegic. An unlikely friendship rebuilds both their lives.","why":"About hope as the right person showing up when you have stopped expecting anyone to.","after":"You’ll be the right person to someone today.","direction":"The chemistry between Cluzet and Sy is the film.","cinematography":"Mathieu Vadepied. Paris without postcard.","musicSound":"Ludovico Einaudi. His most-streamed work.","impact":"The highest-grossing French film ever made.","overall":"A crowd-pleaser that earns every tear."},{"title":"Gifted","director":"Marc Webb","year":2017,"rating":8,"mood":"dawn","story":"A man raises his gifted seven-year-old niece and fights a legal battle against his mother for her.","why":"About hope as the protection of someone’s ordinary childhood against those who would exploit their gifts.","after":"You’ll protect one ordinary thing about someone exceptional.","direction":"Webb handles the material honestly.","cinematography":"Stuart Dryburgh. Florida light.","musicSound":"Rob Simonsen. Small and warm.","impact":"McKenna Grace. An extraordinary child performance.","overall":"A small, honest family film."},{"title":"Wonder","director":"Stephen Chbosky","year":2017,"rating":8.4,"mood":"dawn","story":"A boy born with facial differences attends mainstream school for the first time in fifth grade. The film follows everyone around him.","why":"About hope as the act of being truly seen by someone who could look away.","after":"You’ll really see one person today.","direction":"Chbosky shifts perspectives generously.","cinematography":"Don Burgess. School year.","musicSound":"Marcelo Zarvos.","impact":"Jacob Tremblay and the supporting cast. A generous ensemble.","overall":"A family film with adult intelligence."},{"title":"Captain Fantastic","director":"Matt Ross","year":2016,"rating":8.3,"mood":"gold","story":"A father who raised his children off-grid must navigate the outside world’s expectations.","why":"About hope as the refusal to abandon your values when the world makes it inconvenient.","after":"You’ll question one thing you do because everyone else does.","direction":"Ross makes the idealism complicated.","cinematography":"Stéphane Fontaine.","musicSound":"Alex Somers.","impact":"Viggo Mortensen warmly. Rare.","overall":"Cannes Competition. One of the decade’s better family films."},{"title":"Eddie the Eagle","director":"Dexter Fletcher","year":2015,"rating":7.8,"mood":"gold","story":"Michael Edwards, Britain’s first Olympic ski jumper, finishes last in Calgary 1988 and is beloved for it.","why":"About hope as showing up for the thing you will not win.","after":"You’ll show up for the thing anyway.","direction":"Fletcher treats the material with respect.","cinematography":"George Richmond. Alpine whites.","musicSound":"80s needle drops. Hans Zimmer at the first jump.","impact":"Taron Egerton becoming the actor he would be.","overall":"Modest and warm. Earns its ending."}],"label":"24 films — quick browse"}]}],["$","div",null,{"className":"grid grid-cols-2 gap-x-3 gap-y-5 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-4 sm:gap-x-5 sm:gap-y-7","children":[["$","$L6","The Shawshank Redemption-1994",{"film":"$7"}],["$","$L6","Soul-2020",{"film":"$8"}],["$","$L6","Life is Beautiful-1997",{"film":"$9"}],["$","$L6","Good Will Hunting-1997",{"film":"$a"}],["$","$L6","Little Miss Sunshine-2006",{"film":"$b"}],["$","$L6","Jojo Rabbit-2019",{"film":"$c"}],["$","$L6","About Time-2013",{"film":"$d"}],["$","$L6","The Intouchables-2011",{"film":"$e"}],["$","$L6","Chef-2014",{"film":"$f"}],["$","$L6","Wonder-2017",{"film":"$10"}],["$","$L6","The Green Mile-1999",{"film":"$11"}],["$","$L6","Forrest Gump-1994",{"film":"$12"}],["$","$L6","Schindler's List-1993",{"film":"$13"}],["$","$L6","Slumdog Millionaire-2008",{"film":"$14"}],["$","$L6","Pay It Forward-2000",{"film":"$15"}],["$","$L6","Hacksaw Ridge-2016",{"film":"$16"}],["$","$L6","Hidden Figures-2016",{"film":"$17"}],["$","$L6","Coco-2017",{"film":"$18"}],["$","$L6","Life is Beautiful-1997",{"film":"$19"}],["$","$L6","The Intouchables-2011",{"film":"$1a"}],["$","$L6","Gifted-2017",{"film":"$1b"}],["$","$L6","Wonder-2017",{"film":"$1c"}],["$","$L6","Captain Fantastic-2016",{"film":"$1d"}],["$","$L6","Eddie the Eagle-2015",{"film":"$1e"}]]}]]}],["$","section",null